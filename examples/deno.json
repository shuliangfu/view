{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@dreamer/view",
    "lib": [
      "deno.window",
      "dom"
    ]
  },
  "imports": {
    "@dreamer/view": "../src/mod.ts",
    "@dreamer/view/types": "../src/types.ts",
    "@dreamer/view/cli": "../src/cli.ts",
    "@dreamer/view/jsx-runtime": "../src/jsx-runtime.ts",
    "@dreamer/view/jsx-dev-runtime": "../src/jsx-runtime.ts",
    "@dreamer/view/portal": "../src/runtime/portal.ts",
    "@dreamer/view/compiler": "../src/compiler/mod.ts",
    "@dreamer/view/optimize": "../src/optimize.ts",
    "@dreamer/view/ssr": "../src/runtime/server.ts",
    "@dreamer/plugins": "jsr:@dreamer/plugins@^1.1.0",
    "tailwindcss": "npm:tailwindcss@4.2.0"
  },
  "lint": {
    "include": [
      "src/"
    ],
    "exclude": [
      "dist/"
    ]
  },
  "tasks": {
    "dev": "deno run -A ../src/cli.ts dev",
    "build": "deno run -A ../src/cli.ts build",
    "start": "deno run -A ../src/cli.ts start"
  }
}
