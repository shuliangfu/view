{
  "name": "@dreamer/view",
  "version": "2.0.0-beta.2",
  "license": "Apache-2.0",
  "description": "High-performance reactive UI framework inspired by Solid.js. Features fine-grained reactivity, no virtual DOM, compiler-optimized DOM/SSR paths, and built-in HMR.",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuliangfu/view.git"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./types": "./src/types.ts",
    "./cli": "./src/cli.ts",
    "./setup": "./src/setup.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.ts",
    "./portal": "./src/runtime/portal.ts",
    "./compiler": "./src/compiler/mod.ts",
    "./optimize": "./src/optimize.ts",
    "./ssr": "./src/runtime/server.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "src/**/*.json",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/tests/**"
    ]
  },
  "tasks": {
    "test": "deno test -A tests/unit tests/integration",
    "test:integration": "deno test -A tests/integration",
    "test:e2e": "deno test -A tests/e2e",
    "check": "deno check src/mod.ts",
    "lint": "deno lint src/",
    "fmt": "deno fmt src/ tests/"
  },
  "imports": {
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.18",
    "@dreamer/console": "jsr:@dreamer/console@^1.0.12",
    "@dreamer/esbuild": "jsr:@dreamer/esbuild@^1.1.6",
    "@dreamer/server": "jsr:@dreamer/server@^1.0.9",
    "@dreamer/plugin": "jsr:@dreamer/plugin@^1.0.2",
    "@dreamer/service": "jsr:@dreamer/service@^1.0.2",
    "@dreamer/logger": "jsr:@dreamer/logger@^1.0.3",
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.0.1",
    "@dreamer/test": "jsr:@dreamer/test@^1.1.1",
    "@dreamer/plugins": "jsr:@dreamer/plugins@^1.0.9",
    "@dreamer/view": "./src/mod.ts",
    "@dreamer/view/jsx-runtime": "./src/jsx-runtime.ts",
    "@dreamer/view/jsx-dev-runtime": "./src/jsx-runtime.ts",
    "@dreamer/view/ssr": "./src/runtime/server.ts",
    "@dreamer/view/compiler": "./src/compiler/mod.ts",
    "typescript": "npm:typescript@5.9.3",
    "happy-dom": "npm:happy-dom@20.4.0",
    "cssnano": "npm:cssnano@7.0.3"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@dreamer/view",
    "lib": [
      "deno.window",
      "dom"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any",
        "no-namespace"
      ]
    }
  },
  "exclude": [
    "dist/",
    "tests/data/"
  ],
  "workspace": [
    "examples"
  ]
}
