{
  "name": "@dreamer/view",
  "version": "2.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Lightweight reactive view engine with signals and effects; fine-grained DOM updates without virtual DOM. Supports CSR, SSR, streaming SSR, and hydration. JSX with v-if, v-once, v-cloak and store, router, context.",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuliangfu/view.git"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./types": "./src/types.ts",
    "./cli": "./src/cli.ts",
    "./setup": "./src/setup.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.ts",
    "./compiler": "./src/compiler/mod.ts",
    "./optimize": "./src/optimize.ts",
    "./ssr": "./src/runtime/server.ts",
    "./portal": "./src/runtime/portal.ts"
  },
  "scripts": {
    "test": "bun test --preload ./tests/dom-setup.ts tests/",
    "build": "deno run -A build.ts"
  },
  "dependencies": {
    "@dreamer/console": "npm:@jsr/dreamer__console@^1.0.12",
    "@dreamer/esbuild": "npm:@jsr/dreamer__esbuild@^1.1.6",
    "@dreamer/i18n": "npm:@jsr/dreamer__i18n@^1.0.1",
    "@dreamer/image": "npm:@jsr/dreamer__image@^1.0.2",
    "@dreamer/logger": "npm:@jsr/dreamer__logger@^1.0.3",
    "@dreamer/plugin": "npm:@jsr/dreamer__plugin@^1.0.2",
    "@dreamer/plugins": "npm:@jsr/dreamer__plugins@^1.0.9",
    "@dreamer/runtime-adapter": "npm:@jsr/dreamer__runtime-adapter@^1.0.18",
    "@dreamer/server": "npm:@jsr/dreamer__server@^1.0.9",
    "@dreamer/service": "npm:@jsr/dreamer__service@^1.0.2",
    "@dreamer/test": "npm:@jsr/dreamer__test@^1.1.1",
    "autoprefixer": "npm:autoprefixer@10.4.19",
    "happy-dom": "npm:happy-dom@20.4.0",
    "typescript": "npm:typescript@5.9.3"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "keywords": [
    "view",
    "reactive",
    "jsx",
    "dreamer"
  ],
  "workspace": [
    "examples"
  ]
}
